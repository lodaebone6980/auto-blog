# Railway에서는 자동 설정됨
DATABASE_URL=postgresql://user:pass@localhost:5432/autoblog
NODE_ENV=development
PORT=3000

# 계정 슬롯 ID/PW 서버 암호화 키
# Railway 운영 환경에서는 길고 임의적인 문자열로 반드시 별도 설정하세요.
CREDENTIAL_MASTER_KEY=change-this-to-a-long-random-secret

# AI API (둘 중 하나 이상 설정)
CLAUDE_API_KEY=sk-ant-...
OPENAI_API_KEY=sk-...

# Google Sheets 자동 동기화
# Apps Script 웹앱 URL을 넣으면 content_jobs 변경 시 자동으로 행을 upsert합니다.
GOOGLE_SHEETS_WEBHOOK_URL=https://script.google.com/macros/s/.../exec

# Google Sheets 작업 큐 가져오기
# 시트를 CSV로 게시하거나 CSV export URL을 넣으면 /api/content-jobs/sheets/pull 로 작업을 가져옵니다.
GOOGLE_SHEETS_CSV_URL=https://docs.google.com/spreadsheets/d/.../export?format=csv&gid=0
