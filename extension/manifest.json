{
  "manifest_version": 3,
  "name": "NaviWrite 자동발행",
  "version": "1.4.13",
  "description": "NaviWrite 자동발행 작업과 네이버 작성 화면을 연결합니다.",
  "permissions": [
    "activeTab",
    "clipboardWrite",
    "cookies",
    "sidePanel",
    "scripting",
    "storage",
    "tabs",
    "webNavigation"
  ],
  "host_permissions": [
    "https://web-production-184ff.up.railway.app/*",
    "http://localhost/*",
    "http://127.0.0.1/*",
    "https://*.naver.com/*",
    "https://blog.naver.com/*",
    "https://cafe.naver.com/*",
    "https://contents.premium.naver.com/*",
    "https://brunch.co.kr/*"
  ],
  "action": {
    "default_title": "NaviWrite"
  },
  "side_panel": {
    "default_path": "popup.html"
  },
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": [
        "https://blog.naver.com/*",
        "https://qr.naver.com/*",
        "https://m.site.naver.com/*",
        "https://cafe.naver.com/*",
        "https://contents.premium.naver.com/*",
        "https://brunch.co.kr/*"
      ],
      "js": ["content.js"],
      "all_frames": true,
      "run_at": "document_idle"
    }
  ]
}
